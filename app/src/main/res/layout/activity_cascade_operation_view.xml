<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="controllers.CascadeOperationView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Login"
            android:textSize="16dp" />

        <EditText
            android:id="@+id/edtCascadeKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:ems="10"
            android:hint="API Key"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edtCascadeCookie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:ems="10"
            android:hint="Cookie"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Sale"
            android:textSize="16dp" />

        <EditText
            android:id="@+id/edtCascadeAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:ems="10"
            android:hint="Amount"
            android:inputType="numberDecimal"
            android:text="100"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edtCascadeOperationType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:ems="10"
            android:hint="Operation Type"
            android:editable="false"
            android:text="SALE"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnCascadeStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:enabled="false"
            android:text="Start complete process" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/txtVCascadeResponse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="16sp" />
        </ScrollView>

    </LinearLayout>

    <mx.pagandocheck.pagandodemokotlin.NipPagandoView
        android:id="@+id/nipCascadeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</RelativeLayout>
